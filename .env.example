# Port Configuration
PORT=5000

# MongoDB URI (use local database or Atlas URI)
MONGO_URI=mongodb://127.0.0.1:27017/society_maintenance_tracker

# JWT Security Configurations
JWT_SECRET=your_super_secret_session_jwt_signature_key
JWT_EXPIRES_IN=30d

# Email Transporter SMTP Configurations (Optional, fallbacks to console printing if not provided)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_auth_username
EMAIL_PASS=your_smtp_auth_password

# Email Identity Configurations
FROM_NAME="Society Maintenance Admin"
FROM_EMAIL="noreply@societytracker.com"

# Node Environment
NODE_ENV=development

# Resend API Configuration (Alternate mail delivery, bypassing SMTP port blocks in production)
RESEND_API_KEY=your_resend_api_key_here
